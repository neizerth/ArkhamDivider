# COOP + COEP require-corp: cross-origin isolation for SharedArrayBuffer / wasm-vips pthreads.
# Safari does not treat COEP credentialless as full isolation; use require-corp (see vercel.json).
# External images/fonts/scripts must be CORP-safe (e.g. Cross-Origin-Resource-Policy: cross-origin).
<IfModule mod_headers.c>
  Header always set Cross-Origin-Opener-Policy "same-origin"
  Header always set Cross-Origin-Embedder-Policy "require-corp"
</IfModule>

# WASM MIME type
AddType application/wasm .wasm